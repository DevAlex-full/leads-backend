# ── Servidor ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# URL do frontend (CORS)
ALLOWED_ORIGIN=http://localhost:3000

# ── JWT ───────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_UMA_STRING_ALEATORIA_MUITO_LONGA
JWT_EXPIRES_IN=7d

# ── Supabase ──────────────────────────────────────────────────────
# Obtenha em: https://supabase.com → Project Settings → API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── E-mail (recuperacao de senha) ─────────────────────────────────
# Use Gmail com App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM=Gerador de Leads <seu@gmail.com>

# URL do frontend (para link de reset no e-mail)
FRONTEND_URL=http://localhost:3000

# ── Admin inicial ─────────────────────────────────────────────────
# Preencha para criar o primeiro admin automaticamente ao iniciar
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=SenhaForte123!
ADMIN_NAME=Administrador
